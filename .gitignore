# Ignore arquivos e diretórios gerados automaticamente
_build/
!cmake/**/user.cmake
cmake/**/.generated/*
cmake/**/CMake*
out/
.vscode/

# MPLAB X - arquivos gerados no build
*.d
*.pre
*.p1
*.lst
*.sym
*.obj
*.o
*.sdb
*.obj.dmp
*.map
*.elf
*.hex

# nbproject - apenas os gerados automaticamente
nbproject/private/
nbproject/Package-*.bash
nbproject/Makefile-*
nbproject/Makefile-genesis.properties

# Diretórios de build
build/
dist/
nbbuild/
nbdist/
disassembly/
.generated_files/

# MPLAB X misc
funclist
nbactions.xml
nb-configuration.xml
MPLABXLog.*